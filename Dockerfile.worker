FROM node:22-bookworm AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/

RUN npm run build

FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y ca-certificates curl ffmpeg python3 python3-pip \
  && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get update \
  && apt-get install -y nodejs \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist
COPY scripts/faster_whisper_service.py ./scripts/faster_whisper_service.py

RUN pip3 install --no-cache-dir faster-whisper

ENV VAULT_PATH=/vault
ENV STATE_DIR=/state
ENV FASTER_WHISPER_EXECUTABLE=python3
ENV FASTER_WHISPER_SCRIPT=/app/scripts/faster_whisper_service.py
ENV FASTER_WHISPER_MODEL=large-v3
ENV FASTER_WHISPER_DEVICE=cuda
ENV FASTER_WHISPER_COMPUTE_TYPE=float16
ENV FASTER_WHISPER_DOWNLOAD_ROOT=/state/faster-whisper-cache
ENV PYTHONUNBUFFERED=1

CMD ["node", "dist/transcription/worker.js"]
