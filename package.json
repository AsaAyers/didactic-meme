{
  "name": "didactic-meme",
  "version": "1.0.0",
  "description": "TypeScript-based Markdown automation pipeline",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "run": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "mdast": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^1.0.0"
  }
}
