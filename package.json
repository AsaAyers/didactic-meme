{
  "name": "onyx-vellum",
  "version": "1.0.0",
  "description": "TypeScript-based Markdown automation pipeline",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "onyx-vellum": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "run": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "ollama": "^0.6.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "stringify": "^5.2.0",
    "tiny-invariant": "^1.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "mdast": "^3.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
